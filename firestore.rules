rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own top-level user document and subcollections.
    // Unauthenticated requests are always denied.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Only allow writes with basic field validation (no arbitrary giant payloads)
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly([
                       'email', 'displayName', 'avatar', 'settings',
                       'markingSchemes', 'students', 'assessments', 'updatedAt'
                     ])
                   // Prevent oversized writes (limit to 512 KB as a safety rail)
                   && request.resource.size() < 524288;
    }

    // Allow full access to subcollections under a user's own document
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
